# Database
DATABASE_URL="postgresql://user:password@localhost:5432/trading_journal"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# File Storage (optional - for screenshot uploads)
BLOB_READ_WRITE_TOKEN=""

# Cloudinary (screenshot uploads)
# Cloud name is on Cloudinary Dashboard → API Keys (e.g. dxxxxxxxx) — NOT the word "Upload"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
